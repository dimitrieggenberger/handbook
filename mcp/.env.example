# Handbook MCP adapter configuration.
#
# Copy this file to ".env" (same folder) and fill in real values. The real
# .env is gitignored — never commit it. Real environment variables set in the
# hosting panel override anything here.

# Your Moodle base URL (no trailing slash).
HANDBOOK_BASE_URL=https://learn.europaschule.eu

# The service-account web-service token (the one you created in Moodle).
# Keep it secret: it stays on the server and is never sent to ChatGPT.
HANDBOOK_WSTOKEN=your-moodle-service-account-token

# A long random string YOU invent. ChatGPT must send this as
# "Authorization: Bearer <this>". Generate e.g. with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HANDBOOK_MCP_AUTH_TOKEN=paste-a-long-random-string-here

# readwrite-drafts (default) lets the AI create/update/submit drafts.
# readonly registers no write tools at all.
HANDBOOK_MCP_MODE=readwrite-drafts

# The MCP route. Leave as /mcp unless you have a reason to change it.
HANDBOOK_MCP_PATH=/mcp

# Port: leave UNSET on Infomaniak — the platform injects PORT automatically.
# Only set HANDBOOK_MCP_PORT when running locally for testing.
# HANDBOOK_MCP_PORT=3000
