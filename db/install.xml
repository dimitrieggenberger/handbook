<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/handbook/db" VERSION="2026071526" COMMENT="XMLDB file for local_handbook (specification section 20)"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="local_handbook_category" COMMENT="Handbook categories: nested, ordered, optionally audience-restricted">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="parentid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="slug" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="descriptionformat" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="visible" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="icon" TYPE="char" LENGTH="50" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="audiencekey" TYPE="char" LENGTH="100" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="modifiedby" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="createdby" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="modifiedby" TYPE="foreign" FIELDS="modifiedby" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="slug" UNIQUE="true" FIELDS="slug"/>
        <INDEX NAME="parentorder" UNIQUE="false" FIELDS="parentid, sortorder"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_page" COMMENT="Handbook pages: metadata; publishedrevisionid is the single source of truth for publication state">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="categoryid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="slug" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="summary" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="contenttype" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="procedure"/>
        <FIELD NAME="authoritylevel" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="4"/>
        <FIELD NAME="scopejson" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="audiencejson" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="responsiblearea" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="owneruserid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="approveruserid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="publishedrevisionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="effectivedate" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="reviewdate" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="requiredreading" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="criticality" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="operational"/>
        <FIELD NAME="aiaccess" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="full"/>
        <FIELD NAME="language" TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="es"/>
        <FIELD NAME="translationgroupid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="archived" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="archivereason" TYPE="char" LENGTH="40" NOTNULL="true" DEFAULT="" COMMENT="Structured archive reason (spec 22)"/>
        <FIELD NAME="replacementpageid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Superseding page (0 = none)"/>
        <FIELD NAME="redirectmode" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="" COMMENT="notice_only, redirect_with_notice, automatic_redirect, no_redirect (spec 24)"/>
        <FIELD NAME="archivenote" TYPE="text" NOTNULL="false" COMMENT="Human explanation of the archive/replacement"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="modifiedby" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="categoryid" TYPE="foreign" FIELDS="categoryid" REFTABLE="local_handbook_category" REFFIELDS="id"/>
        <KEY NAME="createdby" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="modifiedby" TYPE="foreign" FIELDS="modifiedby" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="slug" UNIQUE="true" FIELDS="slug"/>
        <INDEX NAME="categoryorder" UNIQUE="false" FIELDS="categoryid, sortorder"/>
        <INDEX NAME="publishedrevision" UNIQUE="false" FIELDS="publishedrevisionid"/>
        <INDEX NAME="reviewdate" UNIQUE="false" FIELDS="reviewdate"/>
        <INDEX NAME="archivedcategory" UNIQUE="false" FIELDS="archived, categoryid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_revision" COMMENT="Page revisions: immutable once published; unique (pageid, versionnumber) guards concurrent draft creation">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="pageid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="versionnumber" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="status" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="draft"/>
        <FIELD NAME="baserevisionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="content" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="contentformat" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="plaintext" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="wordcount" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Word count of the plaintext (plus a small weight per image), for reading-time estimates"/>
        <FIELD NAME="contenthash" TYPE="char" LENGTH="40" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="changesummary" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="reviewnote" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="effectivefrom" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="requiresreacknowledgement" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="modifiedby" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="reviewedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="approvedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="publishedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="authoruserid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Staff-facing published author (0 = fall back to owner/responsible area); set at approval, never from createdby"/>
        <FIELD NAME="timeapproved" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timepublished" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="pageid" TYPE="foreign" FIELDS="pageid" REFTABLE="local_handbook_page" REFFIELDS="id"/>
        <KEY NAME="createdby" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="modifiedby" TYPE="foreign" FIELDS="modifiedby" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="pageversion" UNIQUE="true" FIELDS="pageid, versionnumber"/>
        <INDEX NAME="pagestatus" UNIQUE="false" FIELDS="pageid, status"/>
        <INDEX NAME="status" UNIQUE="false" FIELDS="status"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_relation" COMMENT="Typed directed relationships between pages (specification section 9.2)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="sourcepageid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="targetpageid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="relationtype" TYPE="char" LENGTH="30" NOTNULL="true"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="sourcepageid" TYPE="foreign" FIELDS="sourcepageid" REFTABLE="local_handbook_page" REFFIELDS="id"/>
        <KEY NAME="targetpageid" TYPE="foreign" FIELDS="targetpageid" REFTABLE="local_handbook_page" REFFIELDS="id"/>
        <KEY NAME="createdby" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="sourcetypetarget" UNIQUE="true" FIELDS="sourcepageid, relationtype, targetpageid"/>
        <INDEX NAME="target" UNIQUE="false" FIELDS="targetpageid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_handbook_path" COMMENT="Reading paths: ordered page collections per audience and school year (specification 15)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="slug" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="descriptionformat" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="audiencejson" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="schoolyear" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="active" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="pathtype" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="" COMMENT="onboarding, calendar_phase, role_based, situational, refresher, compliance (spec 6.3)"/>
        <FIELD NAME="estimatedminutes" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="reviewdate" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="quizcmid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="optionalpath" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" COMMENT="1 = recommended (optional) path, 0 = expected reading"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="modifiedby" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="createdby" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="modifiedby" TYPE="foreign" FIELDS="modifiedby" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="slug" UNIQUE="true" FIELDS="slug"/>
        <INDEX NAME="active" UNIQUE="false" FIELDS="active"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_pathitem" COMMENT="Ordered items of a reading path, grouped into named sections (specification 15.3)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="pathid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="pageid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="sectionname" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="required" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="quizcmid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="rationale" TYPE="text" NOTNULL="false" COMMENT="Why this article belongs in the path (spec 6.6)"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="pathid" TYPE="foreign" FIELDS="pathid" REFTABLE="local_handbook_path" REFFIELDS="id"/>
        <KEY NAME="pageid" TYPE="foreign" FIELDS="pageid" REFTABLE="local_handbook_page" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="pathorder" UNIQUE="false" FIELDS="pathid, sortorder"/>
        <INDEX NAME="pathpage" UNIQUE="true" FIELDS="pathid, pageid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_pathrec" COMMENT="Advisory reading-path recommendations; never alter an active path (specification 10)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="pathid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Target path (0 = path-level suggestion)"/>
        <FIELD NAME="pageid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Article the recommendation is about (0 = none)"/>
        <FIELD NAME="revisionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Revision the recommendation was made against"/>
        <FIELD NAME="rectype" TYPE="char" LENGTH="30" NOTNULL="true" COMMENT="add, remove, reorder, replace, split_path, merge_paths, update_required_status"/>
        <FIELD NAME="confidence" TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="medium"/>
        <FIELD NAME="rationale" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="suggestedsection" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="suggestedrequired" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="1" COMMENT="1 required, 0 optional (for add / update_required_status)"/>
        <FIELD NAME="suggestedafterpageid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Ordering hint: place after this page (0 = end)"/>
        <FIELD NAME="status" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="open" COMMENT="open, accepted, dismissed, deferred, already_covered, intentional_omission, resolved"/>
        <FIELD NAME="triggerkind" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="manual" COMMENT="page_published, page_revised, metadata_change, path_proposed, review_due, manual_audit, ai"/>
        <FIELD NAME="source" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="system" COMMENT="system, ai or human"/>
        <FIELD NAME="changesetid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Change set the acceptance drafted into (0 = none)"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="reviewedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="reviewnote" TYPE="text" NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="pathid" TYPE="foreign" FIELDS="pathid" REFTABLE="local_handbook_path" REFFIELDS="id"/>
        <KEY NAME="pageid" TYPE="foreign" FIELDS="pageid" REFTABLE="local_handbook_page" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="statuspath" UNIQUE="false" FIELDS="status, pathid"/>
        <INDEX NAME="pagestatus" UNIQUE="false" FIELDS="pageid, status"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_ack" COMMENT="Required-reading acknowledgements per user and published revision (specification 16)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="pageid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="revisionid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="pathid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="confirmationversion" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="timeacknowledged" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="pageid" TYPE="foreign" FIELDS="pageid" REFTABLE="local_handbook_page" REFFIELDS="id"/>
        <KEY NAME="revisionid" TYPE="foreign" FIELDS="revisionid" REFTABLE="local_handbook_revision" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userrevision" UNIQUE="true" FIELDS="userid, revisionid"/>
        <INDEX NAME="userpage" UNIQUE="false" FIELDS="userid, pageid"/>
        <INDEX NAME="pagetime" UNIQUE="false" FIELDS="pageid, timeacknowledged"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_handbook_readreceipt" COMMENT="Article-level reading completion per user and published revision, shared across every reading path that contains the article (specification 8)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="pageid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="revisionid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="completionmethod" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="reading_path" COMMENT="How completion was recorded (reading_path, manual, ...)"/>
        <FIELD NAME="confirmationversion" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="timecompleted" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="pageid" TYPE="foreign" FIELDS="pageid" REFTABLE="local_handbook_page" REFFIELDS="id"/>
        <KEY NAME="revisionid" TYPE="foreign" FIELDS="revisionid" REFTABLE="local_handbook_revision" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userrevision" UNIQUE="true" FIELDS="userid, revisionid"/>
        <INDEX NAME="userpage" UNIQUE="false" FIELDS="userid, pageid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_handbook_finding" COMMENT="Quality findings from humans, AI tools and scheduled audits (specification 19)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="findingtype" TYPE="char" LENGTH="40" NOTNULL="true"/>
        <FIELD NAME="severity" TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="medium"/>
        <FIELD NAME="confidence" TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="medium"/>
        <FIELD NAME="status" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="open"/>
        <FIELD NAME="summary" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="explanation" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="recommendation" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="source" TYPE="char" LENGTH="40" NOTNULL="true" DEFAULT="human"/>
        <FIELD NAME="externalreference" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="assigneduserid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="resolutionnote" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="modifiedby" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="resolvedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timeresolved" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="createdby" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="modifiedby" TYPE="foreign" FIELDS="modifiedby" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="status" UNIQUE="false" FIELDS="status"/>
        <INDEX NAME="typestatus" UNIQUE="false" FIELDS="findingtype, status"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_findpage" COMMENT="Pages affected by a finding, with optional anchor and excerpt (specification 19.2)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="findingid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="pageid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="revisionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="anchor" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="excerpt" TYPE="text" NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="findingid" TYPE="foreign" FIELDS="findingid" REFTABLE="local_handbook_finding" REFFIELDS="id"/>
        <KEY NAME="pageid" TYPE="foreign" FIELDS="pageid" REFTABLE="local_handbook_page" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="findingpage" UNIQUE="false" FIELDS="findingid, pageid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_changeset" COMMENT="Coordinated multi-page draft proposals, PR-like (specification 36.3)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="instructionsummary" TYPE="text" NOTNULL="false" COMMENT="Concise approved instruction summary; never a full chat transcript"/>
        <FIELD NAME="status" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="draft" COMMENT="draft, in_review, partially_completed, completed, cancelled"/>
        <FIELD NAME="source" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="human" COMMENT="human or ai"/>
        <FIELD NAME="externalreference" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT="" COMMENT="Optional conversation/task id; never a secret"/>
        <FIELD NAME="sponsoruserid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Accountable human requester when known"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timesubmitted" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecompleted" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Technical creator (service account for AI proposals); truthful audit"/>
        <FIELD NAME="modifiedby" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="submittedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="createdby" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="modifiedby" TYPE="foreign" FIELDS="modifiedby" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="status" UNIQUE="false" FIELDS="status"/>
        <INDEX NAME="sourcestatus" UNIQUE="false" FIELDS="source, status"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_changeitem" COMMENT="One proposed change per change set: a page working revision (default) or, in later phases, a metadata/taxonomy/lifecycle/glossary proposal (specification 36.3)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="changesetid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="kind" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="page_revision" COMMENT="Item kind. page_revision (default); future proposal kinds (page_create, page_metadata, page_move, page_archive, page_restore, relation_change, category_change, glossary_*) are applied only by a human-gated dispatcher, never by the API"/>
        <FIELD NAME="pageid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Bound page (0 = no bound page yet; new-page/category/glossary items identify their target via tempkey)"/>
        <FIELD NAME="tempkey" TYPE="char" LENGTH="100" NOTNULL="true" DEFAULT="" COMMENT="Stable id within the change set for an entity with no real id yet (e.g. newpage:slug); resolved to a real id at publish"/>
        <FIELD NAME="revisionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Working revision this item drafts (0 = none, or not a page-revision item)"/>
        <FIELD NAME="itemstatus" TYPE="char" LENGTH="30" NOTNULL="true" DEFAULT="draft" COMMENT="draft, conflict, in_review, approved, published, rejected, skipped"/>
        <FIELD NAME="payloadjson" TYPE="text" NOTNULL="false" COMMENT="Proposed change for non-revision kinds (metadata patch, move, archive, relation, category, glossary); null for page_revision items"/>
        <FIELD NAME="changesummary" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="conflictnote" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="changesetid" TYPE="foreign" FIELDS="changesetid" REFTABLE="local_handbook_changeset" REFFIELDS="id"/>
        <KEY NAME="pageid" TYPE="foreign" FIELDS="pageid" REFTABLE="local_handbook_page" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="changesetorder" UNIQUE="false" FIELDS="changesetid, sortorder"/>
        <INDEX NAME="changesetpage" UNIQUE="false" FIELDS="changesetid, pageid"/>
        <INDEX NAME="changesetkind" UNIQUE="false" FIELDS="changesetid, kind"/>
        <INDEX NAME="revisionid" UNIQUE="false" FIELDS="revisionid"/>
        <INDEX NAME="itemstatus" UNIQUE="false" FIELDS="itemstatus"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_pagealias" COMMENT="Retired page slugs that still resolve to their page (spec 7.3)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="pageid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="oldslug" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="pageid" TYPE="foreign" FIELDS="pageid" REFTABLE="local_handbook_page" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="oldslug" UNIQUE="true" FIELDS="oldslug"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_categoryalias" COMMENT="Retired category slugs that still resolve (spec 4.4)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="categoryid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="oldslug" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="categoryid" TYPE="foreign" FIELDS="categoryid" REFTABLE="local_handbook_category" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="oldslug" UNIQUE="true" FIELDS="oldslug"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_tempref" COMMENT="Temporary-key to real-id map for entities created within a change set (spec 4.3)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="changesetid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="tempkey" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="entitytype" TYPE="char" LENGTH="30" NOTNULL="true" COMMENT="category, page, ..."/>
        <FIELD NAME="entityid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="changesetid" TYPE="foreign" FIELDS="changesetid" REFTABLE="local_handbook_changeset" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="changesettempkey" UNIQUE="true" FIELDS="changesetid, tempkey"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_handbook_area" COMMENT="Controlled vocabulary of responsible areas (spec 9)">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="areakey" TYPE="char" LENGTH="100" NOTNULL="true" COMMENT="Stable machine key"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" COMMENT="Display name stored on pages"/>
        <FIELD NAME="active" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="modifiedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="areakey" UNIQUE="true" FIELDS="areakey"/>
        <INDEX NAME="activesort" UNIQUE="false" FIELDS="active, sortorder"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_handbook_readerhide" COMMENT="Staff temporarily hidden from the reading dashboard (e.g. on leave): a reversible view filter with an audit trail; no reading data is affected">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="note" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="createdby" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="useridunique" UNIQUE="true" FIELDS="userid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
